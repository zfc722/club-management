<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.university.club.mapper.ClubMapper">
  <resultMap id="ClubResult" type="com.university.club.model.Club">
    <id column="id" property="id"/>
    <result column="name" property="name"/>
    <result column="category" property="category"/>
    <result column="president" property="president"/>
    <result column="description" property="description"/>
    <result column="contact" property="contact"/>
    <result column="created_at" property="createdAt"/>
  </resultMap>

  <select id="findAll" resultMap="ClubResult">
    SELECT * FROM club ORDER BY created_at DESC
  </select>

  <select id="findById" parameterType="int" resultMap="ClubResult">
    SELECT * FROM club WHERE id = #{id}
  </select>

  <insert id="insert" parameterType="com.university.club.model.Club" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO club (name, category, president, description, contact, created_at)
    VALUES (#{name}, #{category}, #{president}, #{description}, #{contact}, NOW())
  </insert>

  <update id="update" parameterType="com.university.club.model.Club">
    UPDATE club
    SET name=#{name}, category=#{category}, president=#{president}, description=#{description}, contact=#{contact}
    WHERE id=#{id}
  </update>

  <delete id="delete" parameterType="int">
    DELETE FROM club WHERE id = #{id}
  </delete>

  <select id="search" resultMap="ClubResult">
    SELECT * FROM club
    WHERE 1=1
    <if test="name != null and name != ''">
      AND name LIKE CONCAT('%', #{name}, '%')
    </if>
    <if test="category != null and category != ''">
      AND category = #{category}
    </if>
    ORDER BY created_at DESC
  </select>
</mapper>
